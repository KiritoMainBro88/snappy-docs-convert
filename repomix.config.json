{
  "$schema": "https://repomix.com/schemas/latest/schema.json",
  "output": {
    "filePath": "docs/ai-context/repomix-output.md",
    "style": "markdown",
    "compress": true,
    "removeComments": true,
    "removeEmptyLines": true,
    "showLineNumbers": true,
    "fileSummary": true,
    "directoryStructure": true,
    "files": true,
    "copyToClipboard": false
  },
  "include": [
    "README.md",
    "AGENTS.md",
    "docs/**/*.md",
    "src/**/*.cs",
    "src/**/*.xaml",
    "tests/**/*.cs",
    "*.sln",
    "*.csproj"
  ],
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      ".git/**",
      "bin/**",
      "obj/**",
      "node_modules/**",
      "dist/**",
      "build/**",
      "out/**",
      ".vs/**",
      ".idea/**",
      ".vscode/**",
      "*.user",
      "*.suo",
      "*.log",
      "docs/ai-context/**",
      "**/packages/**",
      "**/TestResults/**",
      "**/*.png",
      "**/*.jpg",
      "**/*.jpeg",
      "**/*.webp",
      "**/*.pdf",
      "**/*.doc",
      "**/*.docx",
      "**/*.ppt",
      "**/*.pptx"
    ]
  },
  "security": {
    "enableSecurityCheck": true
  },
  "tokenCount": {
    "encoding": "o200k_base"
  }
}
