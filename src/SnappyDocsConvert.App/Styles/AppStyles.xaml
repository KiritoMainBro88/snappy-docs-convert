<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F6F7F9" />
    <SolidColorBrush x:Key="AppForegroundBrush" Color="#101828" />
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SoftPanelBrush" Color="#FAFBFC" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#D0D5DD" />
    <SolidColorBrush x:Key="AccentBrush" Color="#1D4ED8" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#EFF6FF" />
    <SolidColorBrush x:Key="MutedBrush" Color="#667085" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#027A48" />
    <SolidColorBrush x:Key="SuccessSoftBrush" Color="#ECFDF3" />
    <SolidColorBrush x:Key="WarningBrush" Color="#B54708" />
    <SolidColorBrush x:Key="WarningSoftBrush" Color="#FFFAEB" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#B42318" />
    <SolidColorBrush x:Key="ErrorSoftBrush" Color="#FEF3F2" />

    <Style x:Key="FocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle Stroke="{StaticResource AccentBrush}"
                               StrokeThickness="2"
                               StrokeDashArray="1 2"
                               SnapsToDevicePixels="True" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button">
        <Setter Property="Margin" Value="6,0,0,0" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
        <Setter Property="Cursor" Value="Hand" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
        <Setter Property="Background" Value="{StaticResource ErrorSoftBrush}" />
        <Setter Property="BorderBrush" Value="#F4B7B2" />
    </Style>

    <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="MinHeight" Value="28" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="NavButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Margin" Value="0,0,0,8" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Background" Value="{StaticResource SoftPanelBrush}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Padding" Value="9,7" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Padding" Value="8,5" />
        <Setter Property="MinHeight" Value="34" />
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
        <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Margin" Value="0,10,0,0" />
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
    </Style>

    <Style x:Key="Panel" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <Style x:Key="SidebarPanel" TargetType="Border" BasedOn="{StaticResource Panel}">
        <Setter Property="Padding" Value="12" />
        <Setter Property="Background" Value="#F9FAFB" />
    </Style>

    <Style x:Key="SettingsGroup" TargetType="Border" BasedOn="{StaticResource Panel}">
        <Setter Property="Background" Value="{StaticResource SoftPanelBrush}" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="EngineCard" TargetType="Border" BasedOn="{StaticResource Panel}">
        <Setter Property="Padding" Value="10" />
        <Setter Property="Margin" Value="0,0,8,8" />
        <Setter Property="Background" Value="{StaticResource SoftPanelBrush}" />
    </Style>

    <Style x:Key="ToolCard" TargetType="Border" BasedOn="{StaticResource Panel}">
        <Setter Property="Padding" Value="14" />
        <Setter Property="Margin" Value="0,0,10,10" />
        <Setter Property="Background" Value="{StaticResource SoftPanelBrush}" />
    </Style>

    <Style x:Key="DropZone" TargetType="Border" BasedOn="{StaticResource Panel}">
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
        <Setter Property="Padding" Value="18" />
    </Style>

    <Style x:Key="PrivacyBadge" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
        <Setter Property="BorderBrush" Value="#ABEFC6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="AlertPanel" TargetType="Border" BasedOn="{StaticResource Panel}">
        <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
        <Setter Property="BorderBrush" Value="#FEDF89" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Margin" Value="0,0,0,12" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding AlertText}" Value="">
                <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TitleText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="30" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SubtitleText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Margin" Value="0,3,0,0" />
    </Style>

    <Style x:Key="SectionTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <Style x:Key="MutedText" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
    </Style>

    <Style x:Key="TinyMutedText" TargetType="TextBlock" BasedOn="{StaticResource MutedText}">
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,10,0,4" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="StatusValueText" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Available">
                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Có sẵn">
                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Missing">
                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Thiếu">
                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Checking">
                <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="Đang kiểm tra">
                <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="LogoInitials" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Visibility" Value="Collapsed" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding LogoPath}" Value="">
                <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
            <DataTrigger Binding="{Binding LogoPath}" Value="{x:Null}">
                <Setter Property="Visibility" Value="Visible" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="StatusPillBorder" TargetType="Border">
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="Background" Value="#F2F4F7" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding Status}" Value="Succeeded">
                <Setter Property="Background" Value="{StaticResource SuccessSoftBrush}" />
                <Setter Property="BorderBrush" Value="#ABEFC6" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="Failed">
                <Setter Property="Background" Value="{StaticResource ErrorSoftBrush}" />
                <Setter Property="BorderBrush" Value="#F4B7B2" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                <Setter Property="Background" Value="{StaticResource WarningSoftBrush}" />
                <Setter Property="BorderBrush" Value="#FEDF89" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="Running">
                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                <Setter Property="BorderBrush" Value="#BFDBFE" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="StatusPillText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding Status}" Value="Succeeded">
                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="Failed">
                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="Running">
                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="Background" Value="{StaticResource PanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RowBackground" Value="{StaticResource PanelBrush}" />
        <Setter Property="AlternatingRowBackground" Value="{StaticResource SoftPanelBrush}" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource BorderBrushSoft}" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource SoftPanelBrush}" />
        <Setter Property="Foreground" Value="{StaticResource AppForegroundBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="8,8" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
    </Style>

    <Style TargetType="DataGridCell">
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}" />
    </Style>

    <Style x:Key="LogListBox" TargetType="ListBox">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="#0F172A" />
        <Setter Property="Foreground" Value="#E5E7EB" />
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="8" />
    </Style>
</ResourceDictionary>
