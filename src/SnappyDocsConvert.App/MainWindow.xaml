<Window x:Class="SnappyDocsConvert.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snappy Docs Convert"
        MinHeight="720"
        MinWidth="1120"
        Height="780"
        Width="1240"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource AppForegroundBrush}"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="170" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Snappy Docs Convert" Style="{StaticResource TitleText}" />
                <TextBlock Text="Local batch document conversion. No cloud upload." Style="{StaticResource MutedText}" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Add Files" Command="{Binding AddFilesCommand}" Style="{StaticResource PrimaryButton}" />
                <Button Content="Add Folder" Command="{Binding AddFolderCommand}" />
                <Button Content="Remove Selected" Command="{Binding RemoveSelectedCommand}" />
                <Button Content="Clear" Command="{Binding ClearCommand}" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,14,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="96" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource DropZone}"
                        Drop="Window_Drop"
                        DragOver="Window_DragOver">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Drop files or folders here" HorizontalAlignment="Center" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text=".pdf .doc .docx .rtf .odt .ppt .pptx .odp" HorizontalAlignment="Center" Style="{StaticResource MutedText}" />
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="1"
                          Margin="0,14,0,0"
                          ItemsSource="{Binding Queue}"
                          SelectedItem="{Binding SelectedQueueItem}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="File name" Binding="{Binding FileName}" Width="2*" />
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="70" />
                        <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="110" />
                        <DataGridTextColumn Header="Engine" Binding="{Binding Engine}" Width="130" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="2*" />
                        <DataGridTextColumn Header="Output" Binding="{Binding Output}" Width="2*" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Border Grid.Column="1" Style="{StaticResource Panel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Settings" Style="{StaticResource SectionTitle}" />

                        <TextBlock Text="Output folder" Style="{StaticResource FieldLabel}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Content="Choose" Command="{Binding ChooseOutputFolderCommand}" Margin="8,0,0,0" />
                        </Grid>

                        <TextBlock Text="Target" Style="{StaticResource FieldLabel}" />
                        <ComboBox ItemsSource="{Binding Targets}" SelectedItem="{Binding SelectedTarget}" />

                        <TextBlock Text="Engine" Style="{StaticResource FieldLabel}" />
                        <ComboBox ItemsSource="{Binding Engines}" SelectedItem="{Binding SelectedEngine}" />

                        <TextBlock Text="Image format" Style="{StaticResource FieldLabel}" />
                        <ComboBox ItemsSource="{Binding ImageFormats}" SelectedItem="{Binding SelectedImageFormat}" />

                        <TextBlock Text="DPI" Style="{StaticResource FieldLabel}" />
                        <TextBox Text="{Binding Dpi, UpdateSourceTrigger=PropertyChanged}" />

                        <CheckBox Content="Keep intermediate PDF" IsChecked="{Binding KeepIntermediatePdf}" Margin="0,12,0,16" />

                        <Separator />
                        <TextBlock Text="Engine setup" Style="{StaticResource SectionTitle}" />
                        <Grid DataContext="{Binding EngineStatus}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Word" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding WordStatus}" Style="{StaticResource StatusText}" />
                            <TextBlock Grid.Row="1" Text="PowerPoint" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PowerPointStatus}" Style="{StaticResource StatusText}" />
                            <TextBlock Grid.Row="2" Text="LibreOffice" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LibreOfficeStatus}" Style="{StaticResource StatusText}" />
                            <TextBlock Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding LibreOfficePath}" Style="{StaticResource MutedText}" TextWrapping="Wrap" />
                            <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Text="{Binding Guidance}" TextWrapping="Wrap" Margin="0,10,0,0" />
                        </Grid>

                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="Recheck" Command="{Binding RecheckEnginesCommand}" />
                            <Button Content="Choose soffice" Command="{Binding ChooseLibreOfficeCommand}" />
                        </StackPanel>
                        <Button Content="Open LibreOffice download" Command="{Binding OpenLibreOfficeDownloadCommand}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource Panel}" Margin="0,14,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="Log" Style="{StaticResource SectionTitle}" />
                <ListBox Grid.Row="1" ItemsSource="{Binding LogLines}" BorderThickness="0" Background="Transparent" />
            </Grid>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,14,0,0">
            <TextBlock DockPanel.Dock="Left" Text="{Binding SummaryText}" VerticalAlignment="Center" Style="{StaticResource MutedText}" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Start Queue" Command="{Binding StartCommand}" Style="{StaticResource PrimaryButton}" />
                <Button Content="Cancel" Command="{Binding CancelCommand}" />
                <Button Content="Open Output Folder" Command="{Binding OpenOutputFolderCommand}" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
