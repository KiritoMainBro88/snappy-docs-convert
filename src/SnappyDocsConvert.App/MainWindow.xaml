<Window x:Class="SnappyDocsConvert.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Snappy Docs Convert"
        MinHeight="720"
        MinWidth="1180"
        Height="820"
        Width="1360"
        Background="{StaticResource AppBackgroundBrush}"
        Foreground="{StaticResource AppForegroundBrush}"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="154" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Snappy Docs Convert" Style="{StaticResource TitleText}" />
                    <Border Style="{StaticResource PrivacyBadge}" Margin="14,3,0,0">
                        <TextBlock Text="Local only · No upload"
                                   Foreground="{StaticResource SuccessBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="12" />
                    </Border>
                </StackPanel>
                <TextBlock Text="Local document converter"
                           Style="{StaticResource SubtitleText}" />
            </StackPanel>

            <WrapPanel Grid.Column="1"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center">
                <Button Content="Add Files" Command="{Binding AddFilesCommand}" Style="{StaticResource PrimaryButton}" />
                <Button Content="Add Folder" Command="{Binding AddFolderCommand}" />
                <Button Content="Remove Selected" Command="{Binding RemoveSelectedCommand}" />
                <Button Content="Clear Queue" Command="{Binding ClearCommand}" />
            </WrapPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="680" />
                <ColumnDefinition Width="388" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,14,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="118" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource DropZone}"
                        Drop="Window_Drop"
                        DragOver="Window_DragOver">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Width="52"
                                Height="52"
                                CornerRadius="26"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="#BFDBFE"
                                BorderThickness="1"
                                VerticalAlignment="Center">
                            <TextBlock Text="+"
                                       FontSize="30"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Drop files or folders here"
                                       FontSize="19"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Supported: PDF, DOC, DOCX, RTF, ODT, PPT, PPTX, ODP"
                                       Style="{StaticResource MutedText}"
                                       Margin="0,4,0,0" />
                            <TextBlock Text="Empty queue? Use Add Files, Add Folder, or drag content into this area."
                                       Style="{StaticResource TinyMutedText}"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <DataGrid Grid.Row="1"
                          Margin="0,14,0,0"
                          ItemsSource="{Binding Queue}"
                          SelectedItem="{Binding SelectedQueueItem}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          AlternationCount="2"
                          RowHeaderWidth="0">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="File" Width="2.2*" MinWidth="190">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding FileName}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding InputPath}" />
                                        <TextBlock Text="{Binding InputPath}"
                                                   Style="{StaticResource TinyMutedText}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding InputPath}" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="66" />
                        <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="115" />
                        <DataGridTextColumn Header="Engine" Binding="{Binding Engine}" Width="126" />
                        <DataGridTemplateColumn Header="Status" Width="118">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource StatusPillBorder}">
                                        <TextBlock Text="{Binding Status}" Style="{StaticResource StatusPillText}" />
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Message" Width="1.8*" MinWidth="190">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Message}"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Message}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Output" Width="1.8*" MinWidth="190">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Output}"
                                               Style="{StaticResource TinyMutedText}"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Output}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="" Width="76">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Open"
                                            Style="{StaticResource SmallButton}"
                                            Command="{Binding DataContext.OpenItemOutputCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Border Grid.Column="1" Style="{StaticResource Panel}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Engine status" Style="{StaticResource SectionTitle}" />
                        <UniformGrid Columns="2" Margin="0,0,0,4" DataContext="{Binding EngineStatus}">
                            <Border Style="{StaticResource EngineCard}">
                                <StackPanel>
                                    <TextBlock Text="Microsoft Word" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding WordStatus}" Style="{StaticResource StatusValueText}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource EngineCard}" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="PowerPoint" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding PowerPointStatus}" Style="{StaticResource StatusValueText}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource EngineCard}">
                                <StackPanel>
                                    <TextBlock Text="LibreOffice" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding LibreOfficeStatus}" Style="{StaticResource StatusValueText}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource EngineCard}" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="PDF renderer" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding PdfRendererStatus}" Style="{StaticResource StatusValueText}" Margin="0,4,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Style="{StaticResource SettingsGroup}">
                            <StackPanel DataContext="{Binding EngineStatus}">
                                <TextBlock Text="Setup guidance" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="{Binding Guidance}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding LibreOfficePath}"
                                           Style="{StaticResource TinyMutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsGroup}">
                            <StackPanel>
                                <TextBlock Text="Output" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="Folder" Style="{StaticResource FieldLabel}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Content="Choose" Command="{Binding ChooseOutputFolderCommand}" Margin="8,0,0,0" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsGroup}">
                            <StackPanel>
                                <TextBlock Text="Conversion" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="Target" Style="{StaticResource FieldLabel}" />
                                <ComboBox ItemsSource="{Binding Targets}" SelectedItem="{Binding SelectedTarget}" />
                                <TextBlock Text="Engine" Style="{StaticResource FieldLabel}" />
                                <ComboBox ItemsSource="{Binding Engines}" SelectedItem="{Binding SelectedEngine}" />
                                <TextBlock Text="{Binding SelectedEngineGuidance}"
                                           Style="{StaticResource TinyMutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsGroup}">
                            <StackPanel>
                                <TextBlock Text="Images" Style="{StaticResource SectionTitle}" />
                                <TextBlock Text="Format" Style="{StaticResource FieldLabel}" />
                                <ComboBox ItemsSource="{Binding ImageFormats}" SelectedItem="{Binding SelectedImageFormat}" />
                                <TextBlock Text="DPI" Style="{StaticResource FieldLabel}" />
                                <TextBox Text="{Binding Dpi, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="72-600 DPI. Default 200. High DPI may use more memory."
                                           Style="{StaticResource TinyMutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0" />
                                <CheckBox Content="Keep intermediate PDF for images-only runs"
                                          IsChecked="{Binding KeepIntermediatePdf}" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsGroup}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="Engines" Style="{StaticResource SectionTitle}" />
                                <WrapPanel>
                                    <Button Content="Recheck" Command="{Binding RecheckEnginesCommand}" Margin="0,0,6,6" />
                                    <Button Content="Choose soffice" Command="{Binding ChooseLibreOfficeCommand}" Margin="0,0,6,6" />
                                </WrapPanel>
                                <Button Content="Open official LibreOffice download"
                                        Command="{Binding OpenLibreOfficeDownloadCommand}"
                                        Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource Panel}" Margin="0,14,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Log" Style="{StaticResource SectionTitle}" />
                    <Button Grid.Column="1"
                            Content="Clear Log"
                            Style="{StaticResource SmallButton}"
                            Command="{Binding ClearLogCommand}" />
                </Grid>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding LogLines}"
                         Style="{StaticResource LogListBox}" />
            </Grid>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource Panel}" Margin="0,14,0,0" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding SummaryText}"
                           VerticalAlignment="Center"
                           Style="{StaticResource MutedText}" />
                <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                    <Button Content="Start Queue" Command="{Binding StartCommand}" Style="{StaticResource PrimaryButton}" />
                    <Button Content="Cancel" Command="{Binding CancelCommand}" Style="{StaticResource DangerButton}" />
                    <Button Content="Open Output" Command="{Binding OpenOutputFolderCommand}" />
                </WrapPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
